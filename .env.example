# ============================================================
# Market-In Aja — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_ID=your-project-ref

# --- Agora RTC ---
EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# --- Xendit Payment Gateway ---
XENDIT_SECRET_KEY=xnd_production_your_secret_key
XENDIT_WEBHOOK_TOKEN=your-xendit-webhook-verification-token
EXPO_PUBLIC_XENDIT_PUBLIC_KEY=xnd_public_your_public_key

# --- Geocoding ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- App Config ---
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1
